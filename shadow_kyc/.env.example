# Shadow-KYC Environment Configuration
# Copy this file to .env and fill in your actual values

# ==================== SEPOLIA NETWORK ====================
# Sepolia Testnet RPC Endpoint
# Get from: https://infura.io or https://alchemy.com
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Your wallet private key (for deployments and transactions)
# WARNING: Never commit this to version control!
# Generate from: MetaMask, Hardhat, or any Ethereum wallet
WALLET_PRIVATE_KEY=your_wallet_private_key_here

# Etherscan API Key for contract verification
# Get from: https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key

# ==================== SMART CONTRACTS ====================
# ZKProofStorage contract address (set after deployment)
# Example: 0x1234567890abcdef1234567890abcdef12345678
ZKPROOF_STORAGE_ADDRESS=0x0000000000000000000000000000000000000000

# Groth16Verifier contract address
VERIFIER_ADDRESS=0x0000000000000000000000000000000000000000

# UserCredentials contract address
CREDENTIALS_ADDRESS=0x0000000000000000000000000000000000000000

# ==================== BACKEND CONFIGURATION ====================
# Backend server configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# KYC Backend (Python) configuration
KYC_BACKEND_URL=http://localhost:8000

# Issuer private key for EdDSA signing
# Generate from issuer key generation script
ISSUER_PRIVATE_KEY=your_issuer_private_key_here

# ==================== FRONTEND CONFIGURATION ====================
# Frontend API endpoint
REACT_APP_API_URL=http://localhost:3000

# Optional: Wallet Connect Project ID
REACT_APP_WALLET_CONNECT_PROJECT_ID=your_wallet_connect_id

# Optional: Pinata API for IPFS uploads
REACT_APP_PINATA_API_KEY=your_pinata_api_key
REACT_APP_PINATA_API_SECRET=your_pinata_api_secret

# ==================== ZK PROOF CONFIGURATION ====================
# Circuit name
CIRCUIT_NAME=kyc

# ZK files directory path
ZK_FILES_PATH=./zk

# ==================== GAS REPORTING ====================
# Enable gas reporting in hardhat
REPORT_GAS=true

# CoinMarketCap API key for gas cost estimation
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key

# ==================== SECURITY ====================
# API Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# JWT secret for API authentication (if implemented)
JWT_SECRET=your_jwt_secret_key_here

# ==================== DATABASE (Optional) ====================
# MongoDB connection string (optional, for proof storage)
MONGODB_URI=mongodb://localhost:27017/shadow_kyc

# Postgres connection (optional)
DATABASE_URL=postgresql://user:password@localhost:5432/shadow_kyc

# ==================== LOGGING ====================
# Log file path
LOG_FILE_PATH=./logs/app.log

# Max log file size (in bytes)
LOG_MAX_SIZE=5242880

# Number of log files to keep
LOG_MAX_FILES=5

# ==================== DEBUGGING ====================
# Enable debug mode
DEBUG=false

# Enable verbose logging
VERBOSE=false
